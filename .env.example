# === Supabase configuration ===
# Base URL for the Supabase project (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key used by the browser client
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key used only by backend tasks (never expose to clients)
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret for verifying Supabase-authenticated requests
SUPABASE_JWT_SECRET=
# Optional: database password for direct Postgres connections (CLI migrations, scripts)
SUPABASE_DB_PASSWORD=

# === Application configuration ===
# Absolute URL for the deployed app (used in emails, callbacks)
NEXT_PUBLIC_APP_URL=
# Contact email or channel for incident paging
INCIDENT_CONTACT=

# === Observability (optional) ===
# Add tracing/logging providers here once selected (e.g., SENTRY_DSN=)
