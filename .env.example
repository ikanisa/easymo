# easyMO environment variable examples (no secret values)
# Update values in Vercel/Supabase dashboards only; do not commit real secrets.

# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""  # Server-side only, never expose to client bundles
SUPABASE_JWT_SECRET=""         # Mirrors Supabase project JWT secret to validate auth tokens

# Application URLs
NEXT_PUBLIC_APP_URL=""         # Base URL for the deployed application (e.g., https://admin.easymo.example)
